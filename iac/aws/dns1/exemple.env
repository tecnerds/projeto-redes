# Exemplo de variáveis de ambiente para iac/aws/dns1
# Não coloque chaves reais neste arquivo em repositórios públicos.

# AWS (opcional se usar perfil)
AWS_PROFILE=default
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Terraform / módulo
TF_VAR_aws_region=us-east-1
TF_VAR_key_pair_name=your-key-name
TF_VAR_private_ip=10.0.1.10
TF_VAR_assign_eip=false
TF_VAR_instance_type=t3.micro
TF_VAR_volume_size=8

# Se quiser parametrizar AMI por região (opcional)
TF_VAR_ami_default=

# Backend S3 (substitua se for usar backend remoto)
TF_BACKEND_S3_BUCKET=REPLACE_WITH_BUCKET
TF_BACKEND_DYNAMODB_TABLE=REPLACE_WITH_DYNAMODB_TABLE

# CIDRs em formato JSON para passar listas via TF_VAR
# Exemplo para SSH: apenas sua faixa de administração
TF_VAR_allowed_ssh_cidrs='["203.0.113.5/32"]'
# Exemplo para DNS: normalmente 0.0.0.0/0 se for resolver público
TF_VAR_dns_allowed_cidrs='["0.0.0.0/0"]'
