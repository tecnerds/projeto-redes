## Exemplo de variáveis de ambiente para iac/proxmox/dns1
# Copie este arquivo para `.env` e preencha os valores reais.

# Proxmox API
PM_API_URL="https://proxmox.example.com:8006/api2/json"
PM_API_TOKEN_ID="terraform@pve!tokenid"
PM_API_TOKEN_SECRET="REPLACE_WITH_SECRET"
TLS_INSECURE=false

# VM parameters
TARGET_NODE="pve"
TEMPLATE="debian-cloud-template"
STORAGE="local-lvm"
BRIDGE="vmbr0"
NAME="dns1"
IP="192.168.1.10"
NETMASK="24"
GATEWAY="192.168.1.1"

# Caminho para chave pública SSH (opcional)
SSH_PUB_KEY="~/.ssh/id_rsa.pub"
